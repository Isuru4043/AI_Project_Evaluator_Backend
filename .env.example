
# Vertex AI Gemini (service-account / ADC authentication)
GOOGLE_APPLICATION_CREDENTIALS=credentials/google-service-account.json
GOOGLE_CLOUD_PROJECT=geminikeyaccess
GOOGLE_CLOUD_LOCATION=global
GEMINI_MODEL=gemini-3.1-flash-lite
# Optional model overrides used by the unified LLM service
# LLM_DEFAULT_MODEL=gemini-3.1-flash-lite
# LLM_FAST_MODEL=gemini-3.1-flash-lite
# LLM_REASONING_MODEL=gemini-3.1-flash-lite

# SonarQube / SonarCloud 
SONAR_HOST_URL=https://sonarcloud.io
SONAR_ORG_KEY=
SONAR_TOKEN=
SONAR_SCANNER_BIN=sonar-scanner

# Cloudinary (optional)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Code analysis tuning (optional)
CODE_ANALYSIS_MAX_ZIP_MB=100
CODE_ANALYSIS_MAX_PROMPT_CHARS=20000
CODE_ANALYSIS_ASYNC=true

# Azure Blob Storage — required for file uploads (reports, video, audio).
# Get these from the storage account: Access keys → Connection string fields.
AZURE_ACCOUNT_NAME=your_storage_account_name
AZURE_ACCOUNT_KEY=your_storage_account_key
AZURE_CONTAINER=media
AZURE_PUBLIC_ACCESS_LEVEL=blob

# RAG retrieval tuning (optional)
# Cross-encoder reranker — set to false to disable for faster/offline runs.
RAG_RERANK_ENABLED=true
RAG_RERANK_MODEL=cross-encoder/ms-marco-MiniLM-L-6-v2

# Agora RTC & STT (video call + live transcription)
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=
AGORA_CUSTOMER_KEY=
AGORA_CUSTOMER_SECRET=
AGORA_STT_ENABLED=false

# CV / Behavioral analysis (exam-station-cv engine)
# Enable only on machines that have the engine's venv installed.
CV_ANALYSIS_ENABLED=false
CV_ANALYSIS_ASYNC=true
# Defaults to <repo>/exam-station-cv/.venv/Scripts/python.exe
# CV_ANALYSIS_PYTHON=
CV_ANALYSIS_TIMEOUT=1800
# Recording storage: 'local' (default, no Azure cost) or 'azure'
CV_RECORDING_STORAGE=local
# CV_RECORDINGS_DIR=  # defaults to <repo>/cv_recordings

# Agora Cloud Recording (server-side channel recording into Azure)
AGORA_CLOUD_RECORDING_ENABLED=false
AGORA_RECORDING_AZURE_REGION=0
